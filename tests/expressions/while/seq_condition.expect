import "primitives/core.futil";
import "primitives/binary_operators.futil";
import "primitives/math.futil";
component main(n: 8) -> (out: 8) {
  cells {
    r = std_reg(8);
    r0 = std_reg(8);
    sqrt = sqrt(8);
    le = std_le(8);
    add = std_add(8);
    mul = std_mult_pipe(8);
    div = std_div_pipe(8);
    eq = std_eq(8);
    mul0 = std_mult_pipe(8);
    eq0 = std_eq(8);
    add0 = std_add(8);
    add1 = std_add(8);
    mux = std_mux(8);
    r1 = std_reg(8);
  }
  wires {
    comb group update {
      add.left = r.out;
      add.right = 8'd1;
    }
    comb group branch {
      mux.cond = eq0.out;
      mux.tru = add0.out;
      mux.fal = add1.out;
      eq0.left = mul0.out;
      eq0.right = n;
      add0.left = r0.out;
      add0.right = 8'd1;
      add1.left = r0.out;
      add1.right = 8'd2;
    }
    comb group cond {
      eq.left = mul.out;
      eq.right = n;
    }
    comb group cond0 {
      le.left = r.out;
      le.right = sqrt.out;
    }
    out = r0.out;
  }
  control {
    seq {
      par {
        invoke r(
          in = 8'd1
        )();
        invoke r0(
          in = 8'd0
        )();
      }
      invoke sqrt(
        in = n
      )();
      while le.out with cond0 {
        seq {
          invoke div(
            left = n,
            right = r.out
          )();
          invoke mul(
            left = div.out_quotient,
            right = r.out
          )();
          if eq.out with cond {
            seq {
              invoke mul0(
                left = r.out,
                right = r.out
              )();
              invoke r1(
                in = mux.out
              )() with branch;
            }
          } else {
            invoke r1(
              in = r0.out
            )();
          }
          par {
            invoke r(
              in = add.out
            )() with update;
            invoke r0(
              in = r1.out
            )();
          }
          invoke sqrt(
            in = n
          )();
        }
      }
    }
  }
}
